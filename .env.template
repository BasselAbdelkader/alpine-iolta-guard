# ============================================================================
# IOLTA Guard - Production Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control
# ============================================================================

# Database Configuration
DB_NAME=iolta_guard_db
DB_USER=iolta_user
DB_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

# Django Configuration
DJANGO_SECRET_KEY=CHANGE_ME_TO_RANDOM_50_CHAR_STRING
DEBUG=False

# Server Configuration
# Add your domain name and server IP here (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# IMPORTANT SECURITY NOTES:
# ============================================================================
# 1. DB_PASSWORD: Use a strong password (at least 20 characters)
# 2. DJANGO_SECRET_KEY: Generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
# 3. ALLOWED_HOSTS: Add your production domain/IP (e.g., example.com,123.45.67.89)
# 4. Never use DEBUG=True in production
# ============================================================================
