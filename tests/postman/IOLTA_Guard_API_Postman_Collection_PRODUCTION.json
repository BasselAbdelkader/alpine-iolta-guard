{
	"info": {
		"_postman_id": "iolta-guard-api-collection",
		"name": "IOLTA Guard - Trust Account Management API",
		"description": "Complete API collection for IOLTA Guard Trust Account Management System.\n\n**Authentication:** Session-based authentication using Django session cookies.\n\n**Base URL:** http://localhost:3000/api\n\n**Getting Started:**\n1. Import this collection into Postman\n2. Import the environment file\n3. Run the 'Login' request first to authenticate\n4. All subsequent requests will use the session cookie automatically\n\n**Important Notes:**\n- All API endpoints require authentication in production\n- Session cookies are HttpOnly and handled automatically\n- CSRF tokens are included in responses and headers\n- All amounts should be positive decimals (e.g., 1000.00)\n- Dates should be in YYYY-MM-DD format",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "iolta-guard-api"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Save session cookie for future requests",
									"if (pm.response.code === 200) {",
									"    pm.environment.set('authenticated', 'true');",
									"    console.log('✓ Login successful - session cookie saved');",
									"} else {",
									"    pm.environment.set('authenticated', 'false');",
									"    console.log('✗ Login failed');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"admin\",\n    \"password\": \"admin123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login/",
							"host": ["{{base_url}}"],
							"path": ["auth", "login", ""]
						},
						"description": "Login to the system using username and password. Returns session cookie for subsequent requests."
					},
					"response": []
				},
				{
					"name": "Check Authentication",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const jsonData = pm.response.json();",
									"    console.log('✓ Authenticated as: ' + jsonData.username);",
									"} else {",
									"    console.log('✗ Not authenticated');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/auth/check/",
							"host": ["{{base_url}}"],
							"path": ["auth", "check", ""]
						},
						"description": "Check if current session is authenticated. Returns user info if authenticated."
					},
					"response": []
				},
				{
					"name": "Logout",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    pm.environment.set('authenticated', 'false');",
									"    console.log('✓ Logout successful');",
									"} else {",
									"    console.log('✗ Logout failed');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/auth/logout/",
							"host": ["{{base_url}}"],
							"path": ["auth", "logout", ""]
						},
						"description": "Logout from the system. Clears session cookie."
					},
					"response": []
				}
			],
			"description": "Authentication endpoints for session-based login/logout"
		},
